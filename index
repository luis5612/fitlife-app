<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="FitLife">
<meta name="theme-color" content="#2d6a4f">
<title>FitLife</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f5f7f5;--surface:#fff;--surface2:#eef2ee;--border:#e0e8e0;
  --green:#2d6a4f;--gl:#52b788;--gp:#d8f3dc;--gm:#74c69d;
  --text:#1a2e1a;--text2:#546a56;--text3:#8fa895;
  --red:#e07070;--redp:#fde8e8;--yellow:#d4a017;
  --r:16px;--rs:10px;--sh:0 1px 12px rgba(45,106,79,.07);--shm:0 4px 20px rgba(45,106,79,.13);
  --navh:72px;--top:env(safe-area-inset-top,44px);--bot:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);max-width:430px;margin:0 auto;overflow-x:hidden;-webkit-font-smoothing:antialiased}

/* SCREENS */
.screen{display:none;flex-direction:column;min-height:100vh;padding-bottom:calc(var(--navh)+4px);animation:fu .22s ease both}
.screen.active{display:flex}
@keyframes fu{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* HEADER */
.hdr{padding:calc(var(--top)+10px) 18px 14px;background:var(--surface);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:20}
.hdr-row{display:flex;justify-content:space-between;align-items:center}
.hdr h1{font-family:'DM Serif Display',serif;font-size:25px;color:var(--green);line-height:1}
.hdr-sub{font-size:11px;color:var(--text3);margin-top:2px}
.badge{background:var(--gp);color:var(--green);font-size:11px;font-weight:600;padding:5px 11px;border-radius:20px;white-space:nowrap}

/* NAV */
.nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:var(--surface);border-top:1px solid var(--border);display:flex;padding:7px 0 calc(var(--bot)+7px);z-index:100}
.ni{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;padding:3px 0;transition:transform .12s;user-select:none}
.ni:active{transform:scale(.88)}
.ni-ic{font-size:20px;line-height:1;transition:transform .15s}
.ni-lb{font-size:10px;font-weight:500;color:var(--text3)}
.ni.active .ni-lb{color:var(--green);font-weight:600}
.ni.active .ni-ic{transform:scale(1.12)}
.ni-pip{width:4px;height:4px;border-radius:50%;background:var(--green);opacity:0;transition:opacity .2s}
.ni.active .ni-pip{opacity:1}

/* CONTENT */
.content{padding:14px 15px 4px;flex:1}

/* CARD */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:15px;margin-bottom:13px;box-shadow:var(--sh)}
.clabel{font-size:10px;font-weight:700;color:var(--text3);letter-spacing:1.2px;text-transform:uppercase;margin-bottom:10px}

/* BANNER */
#apibanner{background:#fff8e0;border:1px solid #f0c040;border-radius:var(--rs);padding:10px 14px;margin:10px 15px 0;font-size:13px;color:#7a5c00;display:none;align-items:center;gap:9px}
#apibanner a{color:var(--green);font-weight:600;cursor:pointer}

/* BUTTONS */
.btn{width:100%;background:var(--green);color:#fff;border:none;border-radius:var(--rs);padding:14px;font-size:15px;font-weight:600;font-family:inherit;cursor:pointer;transition:background .15s,transform .1s}
.btn:active{transform:scale(.98);background:#235a42}
.btn-ghost{width:100%;background:transparent;color:var(--text3);border:none;padding:10px;font-size:14px;font-family:inherit;cursor:pointer}
.bsend{background:var(--green);color:#fff;border:none;border-radius:var(--rs);width:43px;height:43px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s,transform .1s;flex-shrink:0;align-self:flex-end}
.bsend:active{transform:scale(.9);background:#235a42}

/* CHIPS */
.chips{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:15px}
.chip{background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:6px 13px;font-size:12px;font-weight:500;color:var(--text2);cursor:pointer;transition:all .12s;white-space:nowrap;user-select:none}
.chip:active,.chip.on{background:var(--gp);border-color:var(--gm);color:var(--green)}

/* INPUT AREA */
.ia{display:flex;gap:8px;margin-bottom:15px}
.ia textarea{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px 12px;font-family:inherit;font-size:14px;color:var(--text);outline:none;resize:none;transition:border .12s;line-height:1.5}
.ia textarea:focus{border-color:var(--gl)}

/* LOADING */
.ldw{display:none;padding:10px 0}
.ldw.on{display:flex}
.ld{display:flex;gap:5px;align-items:center}
.ld span{width:7px;height:7px;border-radius:50%;background:var(--gm);animation:db 1.2s infinite}
.ld span:nth-child(2){animation-delay:.15s}
.ld span:nth-child(3){animation-delay:.3s}
@keyframes db{0%,60%,100%{transform:translateY(0);opacity:.7}30%{transform:translateY(-7px);opacity:1}}

/* RESPONSE BOX */
.rbox{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--gm);border-radius:var(--r);padding:15px;margin-bottom:13px;font-size:14px;color:var(--text);line-height:1.7;white-space:pre-wrap;display:none}
.rbox.on{display:block;animation:fu .3s ease}

/* MODAL */
.moverlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);backdrop-filter:blur(6px);z-index:300;align-items:flex-end;justify-content:center}
.moverlay.on{display:flex}
.modal{background:var(--surface);border-radius:22px 22px 0 0;padding:26px 20px calc(var(--bot)+26px);width:100%;max-width:430px;animation:su .26s ease}
@keyframes su{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal h2{font-family:'DM Serif Display',serif;font-size:21px;margin-bottom:8px}
.modal p{font-size:14px;color:var(--text2);margin-bottom:16px;line-height:1.6}
.modal input{width:100%;border:1px solid var(--border);border-radius:var(--rs);padding:12px 13px;font-size:14px;font-family:inherit;outline:none;margin-bottom:11px;color:var(--text);background:var(--bg)}
.modal input:focus{border-color:var(--gl);background:#fff}

/* ══ HOME ══ */
.hero{background:linear-gradient(140deg,#1f5438 0%,var(--gl) 100%);border-radius:var(--r);padding:20px 18px 18px;color:#fff;margin-bottom:13px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;right:-20px;top:-20px;width:110px;height:110px;border-radius:50%;background:rgba(255,255,255,.07)}
.hero-greet{font-size:11px;opacity:.72;margin-bottom:3px;letter-spacing:.4px;text-transform:uppercase}
.hero h2{font-family:'DM Serif Display',serif;font-size:23px;line-height:1.2;margin-bottom:11px}
.hero-stats{display:flex;gap:18px}
.hstat-n{font-family:'DM Serif Display',serif;font-size:22px;line-height:1}
.hstat-l{font-size:10px;opacity:.68;margin-top:2px}

/* NEXT UP */
.next-hdr{font-size:10px;font-weight:700;color:var(--text3);letter-spacing:1.2px;text-transform:uppercase;margin-bottom:9px}
.nc{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:13px 14px;margin-bottom:10px;box-shadow:var(--sh);display:flex;align-items:center;gap:12px;transition:border-color .15s}
.nc.done{opacity:.5}
.nc.done .nc-name{text-decoration:line-through;color:var(--text3)}
.nc.empty{border-style:dashed;cursor:pointer}
.nc.empty:active{opacity:.7}
.nc-ico{width:42px;height:42px;border-radius:11px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px}
.nc-ico.wo{background:#d8f3dc}
.nc-ico.ml{background:#e8f4ff}
.nc-ico.em{background:var(--surface2);font-size:18px;color:var(--text3)}
.nc-body{flex:1;min-width:0}
.nc-tag{font-size:10px;font-weight:600;color:var(--text3);letter-spacing:.7px;text-transform:uppercase;margin-bottom:2px}
.nc-name{font-size:15px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nc-meta{font-size:12px;color:var(--text3);margin-top:2px}
.nc-meta.tmrw{color:var(--yellow);font-weight:500}
.nc-chk{width:29px;height:29px;border-radius:50%;border:2px solid var(--border);background:var(--bg);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .18s;font-size:13px;color:transparent;flex-shrink:0}
.nc-chk.on{background:var(--green);border-color:var(--green);color:#fff}

/* QUICK ACTIONS */
.qgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:13px}
.qcard{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:13px;cursor:pointer;transition:all .12s;user-select:none}
.qcard:active{transform:scale(.96);border-color:var(--gm)}
.qico{font-size:22px;margin-bottom:6px}
.qtitle{font-size:13px;font-weight:600;color:var(--text)}
.qsub{font-size:11px;color:var(--text3);margin-top:1px}

/* STATS ROW */
.srow{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:13px}
.sc{background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:12px 8px;text-align:center}
.sc-n{font-family:'DM Serif Display',serif;font-size:25px;color:var(--green)}
.sc-l{font-size:10px;color:var(--text3);margin-top:2px}

/* TABS */
.tabs{display:flex;background:var(--surface2);border-radius:var(--rs);padding:3px;margin-bottom:15px;gap:2px}
.tab{flex:1;text-align:center;padding:9px 5px;font-size:12px;font-weight:500;color:var(--text3);border-radius:8px;cursor:pointer;transition:all .12s}
.tab.on{background:var(--surface);color:var(--green);font-weight:600;box-shadow:0 1px 5px rgba(0,0,0,.08)}

/* DIET */
.mcard{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:10px}
.mhdr{padding:11px 13px;background:var(--surface2);display:flex;justify-content:space-between;align-items:center;cursor:pointer}
.mtitle{font-size:13px;font-weight:600;color:var(--text)}
.mbadge{background:var(--gp);color:var(--green);font-size:11px;font-weight:600;padding:3px 8px;border-radius:8px}
.mbody{padding:11px 13px;display:none}
.mbody.on{display:block}

/* SHOPPING */
.si{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.si:last-child{border:none}
.schk{width:21px;height:21px;border-radius:6px;border:2px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
.schk.on{background:var(--green);border-color:var(--green)}
.schk.on::after{content:'✓';color:#fff;font-size:11px;font-weight:700}
.sname{flex:1;font-size:14px;color:var(--text)}
.sname.done{text-decoration:line-through;color:var(--text3)}
.sprice{font-size:13px;font-weight:600;color:var(--green)}

/* SEGUIMIENTO */
.wrow{display:flex;gap:5px;margin-bottom:13px}
.db{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:7px 0;border-radius:10px}
.db .dn{font-size:9px;color:var(--text3);font-weight:600;letter-spacing:.5px;text-transform:uppercase}
.db .dd{font-size:14px;font-weight:600;color:var(--text2)}
.db .dp{width:5px;height:5px;border-radius:50%;background:var(--border)}
.db.hd .dp{background:var(--gm)}
.db.td{background:var(--gp)}
.db.td .dn,.db.td .dd{color:var(--green)}

.ring-wrap{display:flex;flex-direction:column;align-items:center;padding:10px 0 4px}
svg.ring{transform:rotate(-90deg)}
.rbg{fill:none;stroke:var(--border);stroke-width:9}
.rfill{fill:none;stroke:var(--gl);stroke-width:9;stroke-linecap:round;transition:stroke-dashoffset .7s cubic-bezier(.4,0,.2,1)}
.rc{font-family:'DM Serif Display',serif;font-size:29px;fill:var(--green)}
.rs{font-size:11px;fill:var(--text3)}

.lbrow{display:flex;gap:7px;margin-bottom:7px}
.lblog{flex:1;background:var(--gp);color:var(--green);border:1px solid #b7e4c7;border-radius:var(--rs);padding:10px 6px;font-size:12px;font-weight:600;font-family:inherit;cursor:pointer;transition:all .12s;text-align:center}
.lblog:active{transform:scale(.95)}
.lblog.red{background:var(--redp);color:var(--red);border-color:#f0b0b0}

.litem{display:flex;gap:9px;align-items:flex-start;padding:9px 0;border-bottom:1px solid var(--border)}
.litem:last-child{border:none}
.ldot{width:8px;height:8px;border-radius:50%;margin-top:4px;flex-shrink:0}
.ldot.g{background:var(--gm)}
.ldot.r{background:var(--red)}
.ltext{font-size:13px;color:var(--text2)}
.ltime{font-size:11px;color:var(--text3);margin-top:1px}

/* WORKOUT */
.excard{background:var(--surface2);border-radius:var(--rs);padding:12px;margin-bottom:8px;border-left:3px solid var(--gm)}
.exname{font-weight:600;font-size:14px;color:var(--text);margin-bottom:5px}
.extag{display:inline-block;background:var(--gp);color:var(--green);font-size:10px;font-weight:700;padding:2px 7px;border-radius:7px;margin-right:4px;margin-bottom:2px}
.exval{font-size:12px;color:var(--text2)}

/* PERFIL */
.pavatar{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--gp),var(--gm));display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:9px}
.srow2{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:opacity .1s}
.srow2:active{opacity:.6}
.srow2:last-child{border:none}
.slabel{font-size:14px;color:var(--text)}
.sval{font-size:13px;color:var(--text3)}

/* CHAT FAB */
.cfab{position:fixed;bottom:calc(var(--navh)+10px);right:15px;z-index:110;width:50px;height:50px;border-radius:50%;background:var(--green);box-shadow:0 4px 16px rgba(45,106,79,.38);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:21px;transition:transform .18s,box-shadow .18s}
.cfab:hover{transform:scale(1.06)}
.cfab:active{transform:scale(.9)}

.coverlay{position:fixed;inset:0;background:rgba(0,0,0,.32);backdrop-filter:blur(3px);z-index:120;opacity:0;pointer-events:none;transition:opacity .22s}
.coverlay.on{opacity:1;pointer-events:all}

.cdrawer{position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);width:100%;max-width:430px;height:80vh;background:var(--surface);border-radius:22px 22px 0 0;box-shadow:0 -4px 28px rgba(0,0,0,.13);z-index:130;display:flex;flex-direction:column;transition:transform .3s cubic-bezier(.32,.72,0,1)}
.cdrawer.on{transform:translateX(-50%) translateY(0)}

.chandle{width:34px;height:4px;border-radius:2px;background:var(--border);margin:9px auto 0;flex-shrink:0}
.chdr{padding:9px 16px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0}
.cav{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--green),var(--gl));display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.chdrinfo h3{font-size:14px;font-weight:600;color:var(--text)}
.chdrinfo p{font-size:11px;color:var(--gl);font-weight:500}
.ccls{width:28px;height:28px;border-radius:50%;background:var(--surface2);border:none;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;color:var(--text3)}

.cmsgs{flex:1;overflow-y:auto;padding:12px 13px 6px;display:flex;flex-direction:column;gap:8px;scroll-behavior:smooth;-webkit-overflow-scrolling:touch}
.cmsg{display:flex;gap:7px;align-items:flex-end;max-width:86%}
.cmsg.user{align-self:flex-end;flex-direction:row-reverse}
.cmsg.ai{align-self:flex-start}
.mbub{padding:9px 12px;border-radius:17px;font-size:14px;line-height:1.55;white-space:pre-wrap;word-break:break-word}
.cmsg.ai .mbub{background:var(--surface2);color:var(--text);border-bottom-left-radius:4px}
.cmsg.user .mbub{background:var(--green);color:#fff;border-bottom-right-radius:4px}
.mav{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0}
.cmsg.ai .mav{background:var(--gp)}
.cmsg.user .mav{background:var(--gm)}

.typbub{display:none;align-self:flex-start;align-items:center;gap:4px;background:var(--surface2);padding:10px 13px;border-radius:17px;border-bottom-left-radius:4px}
.typbub.on{display:flex}
.typbub span{width:6px;height:6px;border-radius:50%;background:var(--text3);animation:db 1.2s infinite}
.typbub span:nth-child(2){animation-delay:.15s}
.typbub span:nth-child(3){animation-delay:.3s}

.csugs{display:flex;gap:6px;overflow-x:auto;padding:7px 13px 4px;scrollbar-width:none;flex-shrink:0;-webkit-overflow-scrolling:touch}
.csugs::-webkit-scrollbar{display:none}
.csug{white-space:nowrap;background:var(--gp);border:1px solid #b7e4c7;border-radius:15px;padding:5px 11px;font-size:12px;font-weight:500;color:var(--green);cursor:pointer;flex-shrink:0}
.csug:active{background:#b7e4c7}

.cinrow{padding:8px 11px calc(var(--bot)+12px);display:flex;gap:8px;align-items:flex-end;border-top:1px solid var(--border);flex-shrink:0}
.cinrow textarea{flex:1;border:1px solid var(--border);border-radius:17px;padding:9px 13px;font-family:inherit;font-size:14px;color:var(--text);outline:none;resize:none;max-height:86px;line-height:1.4;transition:border .12s;background:var(--surface2)}
.cinrow textarea:focus{border-color:var(--gl);background:#fff}
.csend{width:38px;height:38px;border-radius:50%;background:var(--green);color:#fff;border:none;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .12s,transform .1s;flex-shrink:0}
.csend:active{transform:scale(.88)}
.csend:disabled{background:var(--border);cursor:not-allowed}

.section-sub{font-size:13px;color:var(--text3);margin-bottom:14px;line-height:1.5}
</style>
</head>
<body>

<div class="coverlay" id="coverlay" onclick="closeChat()"></div>
<div class="cdrawer" id="cdrawer">
  <div class="chandle"></div>
  <div class="chdr">
    <div class="cav">&#127807;</div>
    <div class="chdrinfo" style="flex:1"><h3>Asistente FitLife</h3><p>&#9679; En l&iacute;nea</p></div>
    <button class="ccls" onclick="closeChat()">&#x2715;</button>
  </div>
  <div class="cmsgs" id="cmsgs"></div>
  <div class="typbub" id="typbub"><span></span><span></span><span></span></div>
  <div class="csugs">
    <div class="csug" onclick="cSug(this)">Rutina de hoy</div>
    <div class="csug" onclick="cSug(this)">Plan dieta semanal</div>
    <div class="csug" onclick="cSug(this)">A&ntilde;adir ejercicio b&iacute;ceps</div>
    <div class="csug" onclick="cSug(this)">Quitar un ejercicio</div>
    <div class="csug" onclick="cSug(this)">Sustituir una comida</div>
    <div class="csug" onclick="cSug(this)">Lista de la compra</div>
    <div class="csug" onclick="cSug(this)">M&aacute;s prote&iacute;nas</div>
  </div>
  <div class="cinrow">
    <textarea id="cin" rows="1" placeholder="P&iacute;deme cualquier cambio&#x2026;" onkeydown="ckd(event)" oninput="car(this)"></textarea>
    <button class="csend" id="csend" onclick="sendChat()">&#x2191;</button>
  </div>
</div>
<button class="cfab" id="cfab" onclick="openChat()">&#x1F4AC;</button>

<div class="moverlay" id="apimodal">
  <div class="modal">
    <h2>Configura la IA</h2>
    <p>Introduce tu API key de Anthropic para activar el asistente de entreno y dieta con inteligencia artificial.</p>
    <input type="password" id="apikeyinput" placeholder="sk-ant-&#x2026;" autocomplete="off" onkeydown="if(event.key==='Enter')saveKey()">
    <button class="btn" onclick="saveKey()">Guardar y activar</button>
    <button class="btn-ghost" onclick="closeModal()">Ahora no</button>
  </div>
</div>

<!-- ══ HOME ══ -->
<div class="screen active" id="screen-home">
  <div class="hdr">
    <div class="hdr-row">
      <div><h1>FitLife</h1><div class="hdr-sub" id="greeting">Buenos d&iacute;as</div></div>
      <div class="badge" id="streakbadge">&#x1F525; 0 d&iacute;as</div>
    </div>
  </div>
  <div id="apibanner" style="display:none">
