}

function showBanner(){const b=g$('apibanner');if(b)b.style.display='flex';g$('apistatus','No configurada')}
function hideBanner(){const b=g$('apibanner');if(b)b.style.display='none';g$('apistatus','✓ Activa')}

function nav(s){
  document.querySelectorAll('.screen').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.ni').forEach(x=>x.classList.remove('active'));
  const sc=document.getElementById('screen-'+s);
  const ni=document.getElementById('nav-'+s);
  if(sc)sc.classList.add('active');
  if(ni)ni.classList.add('active');
  if(s==='seguimiento'){renderWeekCal();refreshStats();refreshRing();renderHistory()}
  if(s==='home'){renderNextUp();refreshHomeStats()}
  window.scrollTo(0,0);
}

function openModal(){
  g$('apimodal').classList.add('on');
  const i=g$('apikeyinput');
  i.value=apiKey||'';
  setTimeout(()=>i.focus(),280);
}
function closeModal(){g$('apimodal').classList.remove('on')}
function saveKey(){
  const v=g$('apikeyinput').value.trim();
  if(!v){alert('Introduce una API key válida');return}
  apiKey=v; S.set('fl_k',v);
  closeModal(); hideBanner();
}

function chip(el,t){
  el.closest('.chips').querySelectorAll('.chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  const txt=el.textContent.trim();
  if(t==='t'){const i=g$('tinput');if(i)i.value=txt}
  if(t==='d'){const i=g$('dinput');if(i)i.value=txt}
}

async function callAI(sys,user,maxTok=1800){
  if(!apiKey){openModal();throw new Error('no_key')}
  const r=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:maxTok,system:sys,messages:[{role:'user',content:user}]})
  });
  if(!r.ok){const e=await r.json().catch(()=>({}));throw new Error(e.error?.message||'Error '+r.status)}
  const d=await r.json();
  return d.content[0].text;
}

async function askTrainer(){
  const inp=g$('tinput');
  const txt=inp.value.trim();
  if(!txt)return;
  const sys=`Eres un entrenador personal experto en gimnasio. Responde SIEMPRE en español.
Usa este formato exacto:

RUTINA: [nombre]
OBJETIVO: [objetivo]
DURACIÓN: [tiempo total]

CALENTAMIENTO: [descripción]

EJERCICIO 1: [nombre]
Series/reps: [ej: 4 x 10]
Descanso: [ej: 60 seg]
Nota: [tip técnico]

(repite para cada ejercicio)

VUELTA A LA CALMA: [descripción]
${pCtx()}`;
  setLoad('tload',true);
  g$('trbox').classList.remove('on');
  g$('trex').innerHTML='';
  try{
    const res=await callAI(sys,txt);
    workoutPlan=res; S.set('fl_w',res);
    renderWorkout(res);
    renderNextUp();
  }catch(e){if(e.message!=='no_key')alert('Error: '+e.message)}
  finally{setLoad('tload',false)}
}

function renderWorkout(text){
  const box=g$('trbox'),exd=g$('trex');
  const lines=text.split('\n');
  let hdr='',html='',inHdr=true,inEx=false;
  lines.forEach(l=>{
    const t=l.trim();if(!t)return;
    if(/^EJERCICIO\s*\d+:/i.test(t)){
      if(inEx)html+='</div>';
      inHdr=false;inEx=true;
      html+=`<div class="excard"><div class="exname">${esc(t.replace(/^EJERCICIO\s*\d+:\s*/i,''))}</div>`;
    } else if(inEx&&/^(Series\/reps|Descanso|Nota):/i.test(t)){
      const ci=t.indexOf(':');
      html+=`<span class="extag">${esc(t.substring(0,ci))}</span><span class="exval"> ${esc(t.substring(ci+1).trim())}</span><br>`;
    } else if(/^(CALENTAMIENTO|VUELTA A LA CALMA):/i.test(t)){
      if(inEx){html+='</div>';inEx=false}
      inHdr=false;
      const ci=t.indexOf(':');
      html+=`<div class="excard" style="border-left-color:var(--border)"><div class="exname" style="color:var(--text2);font-size:13px">${esc(t.substring(0,ci))}</div><div class="exval">${esc(t.substring(ci+1).trim())}</div></div>`;
    } else if(inHdr){hdr+=t+'\n'}
    else if(inEx){html+=`<span class="exval">${esc(t)}</span><br>`}
  });
  if(inEx)html+='</div>';
  box.textContent=hdr.trim();
  if(hdr.trim())box.classList.add('on');
  exd.innerHTML=html;
}

async function askDiet(){
  const inp=g$('dinput');
  const txt=inp.value.trim();
  if(!txt)return;
  const sys=`Eres un nutricionista experto. Responde SIEMPRE en español.
Genera un plan de dieta semanal con este formato:

DIETA: [nombre]
CALORÍAS ESTIMADAS: [kcal/día]
OBJETIVO: [descripción]

DÍA 1 - LUNES:
DESAYUNO: [nombre del plato]
  Ingredientes: [lista con cantidades]
  Prep: [1-2 frases]
COMIDA: [nombre]
  Ingredientes: [lista]
  Prep: [1 frase]
CENA: [nombre]
  Ingredientes: [lista]

(repite para los 7 días)

NOTAS NUTRICIONALES: [2-3 puntos clave]
${pCtx()}`;
  setLoad('dload',true);
  g$('drbox').classList.remove('on');
  g$('dmeals').innerHTML='';
  try{
    const res=await callAI(sys,txt,2400);
    dietPlan=res; S.set('fl_d',res);
    renderDiet(res);
    renderNextUp();
  }catch(e){if(e.message!=='no_key')alert('Error: '+e.message)}
  finally{setLoad('dload',false)}
}

function renderDiet(text){
  const box=g$('drbox'),md=g$('dmeals');
  const lines=text.split('\n');
  let hdr='',html='',inDay=false;
  lines.forEach(l=>{
    const t=l.trim();if(!t)return;
    if(/^D[ÍI]A\s+\d/i.test(t)){
      if(inDay)html+='</div></div>';
      inDay=true;
      html+=`<div class="mcard"><div class="mhdr" onclick="tmeal(this)"><span class="mtitle">${esc(t)}</span><span class="mbadge">Ver</span></div><div class="mbody">`;
    } else if(inDay&&/^(DESAYUNO|COMIDA|CENA|MERIENDA|SNACK):/i.test(t)){
      html+=`<p style="font-weight:600;font-size:13px;color:var(--green);margin:9px 0 3px">${esc(t)}</p>`;
    } else if(inDay&&/^(Ingredientes|Prep):/i.test(t)){
      html+=`<p style="font-size:12px;color:var(--text2);margin-bottom:3px;line-height:1.5">${esc(t)}</p>`;
    } else if(/^NOTAS/i.test(t)){
      if(inDay){html+='</div></div>';inDay=false}
      html+=`<div class="card"><div class="clabel">Notas nutricionales</div><p style="font-size:13px;color:var(--text2);line-height:1.6">${esc(t.replace(/^NOTAS NUTRICIONALES:\s*/i,''))}</p></div>`;
    } else if(/^(DIETA|CALORÍAS|OBJETIVO):/i.test(t)){hdr+=t+'\n'}
    else if(inDay){html+=`<p style="font-size:12px;color:var(--text2);line-height:1.5">${esc(t)}</p>`}
    else{hdr+=t+'\n'}
  });
  if(inDay)html+='</div></div>';
  box.textContent=hdr.trim();
  hdr.trim()?box.classList.add('on'):box.classList.remove('on');
  md.innerHTML=html;
}

function tmeal(h){
  const b=h.nextElementSibling;
  b.classList.toggle('on');
  h.querySelector('.mbadge').textContent=b.classList.contains('on')?'Cerrar':'Ver';
}

async function genShop(){
  if(!dietPlan){alert('Genera primero un plan de dieta.');return}
  const sys=`Experto en compras de supermercado en Madrid, España.
Basándote en el plan de dieta, genera una lista de la compra semanal consolidada.
Responde SOLO con JSON válido, sin markdown ni texto extra:
{"items":[{"nombre":"Huevos","cantidad":"12 uds","precio_mercadona":2.10,"precio_lidl":1.89,"precio_carrefour":2.30,"categoria":"Proteínas"}],"total_estimado":85.50}
Categorías: Frutas y verduras, Proteínas, Lácteos, Cereales y legumbres, Grasas saludables, Otros.`;
  setLoad('shopload',true);
  g$('shoplist').innerHTML='';
  g$('shoptotal').style.display='none';
  try{
    const res=await callAI(sys,dietPlan,2000);
    const data=JSON.parse(res.replace(/```[\w]*\n?/g,'').trim());
    renderShop(data);
  }catch(e){
    if(e.message!=='no_key'){
      if(e instanceof SyntaxError)alert('Formato inesperado. Intenta de nuevo.');
      else alert('Error: '+e.message);
    }
  }
  finally{setLoad('shopload',false)}
}

function renderShop(data){
  const cats={};
  data.items.forEach(item=>{
    const c=item.categoria||'Otros';
    if(!cats[c])cats[c]=[];
    cats[c].push(item);
  });
  let html='';
  Object.keys(cats).forEach(cat=>{
    html+=`<div class="card"><div class="clabel">${esc(cat)}</div>`;
    cats[cat].forEach((item,i)=>{
      const id='si_'+btoa(encodeURIComponent(cat+i)).replace(/[^a-z0-9]/gi,'').substring(0,12);
      const ps=[item.precio_mercadona,item.precio_lidl,item.precio_carrefour].filter(p=>typeof p==='number');
      const best=ps.length?Math.min(...ps):0;
      const st=item.precio_mercadona===best?'Mercadona':item.precio_lidl===best?'Lidl':'Carrefour';
      html+=`<div class="si" id="${id}">
        <div class="schk" onclick="tcheck('${id}',this)"></div>
        <div style="flex:1;min-width:0"><div class="sname">${esc(item.nombre)}</div><div style="font-size:11px;color:var(--text3)">${esc(item.cantidad||'')} &middot; ${st}</div></div>
        <div style="text-align:right;flex-shrink:0"><div class="sprice">&euro;${best.toFixed(2)}</div><div style="font-size:10px;color:var(--text3)">${st}</div></div>
      </div>`;
    });
    html+='</div>';
  });
  g$('shoplist').innerHTML=html;
  g$('shoptotal').style.display='block';
  g$('totalprice').textContent='€'+(data.total_estimado||0).toFixed(2);
}

function tcheck(id,el){
  el.classList.toggle('on');
  document.querySelector('#'+id+' .sname').classList.toggle('done');
}

function dtab(tab,el){
  document.querySelectorAll('#screen-dieta .tab').forEach(t=>t.classList.remove('on'));
  el.classList.add('on');
  g$('dplantab').style.display=tab==='plan'?'block':'none';
  g$('dcompratab').style.display=tab==='compra'?'block':'none';
}

function renderNextUp(){renderNextWorkout();renderNextMeal()}

function renderNextWorkout(){
  const c=g$('ncw');
  if(!workoutPlan){
    c.innerHTML=`<div class="nc empty" onclick="nav('entrenador')"><div class="nc-ico em">+</div><div class="nc-body"><div class="nc-tag">ENTRENO</div><div class="nc-name" style="color:var(--text3)">Genera tu primera rutina</div></div></div>`;
    return;
  }
  const nm=(workoutPlan.match(/RUTINA:\s*(.+)/i)||[])[1]||'Mi rutina';
  const dur=(workoutPlan.match(/DURACI[ÓO]N:\s*(.+)/i)||[])[1]||'';
  const done=getChecks().workout;
  c.innerHTML=`<div class="nc${done?' done':''}">
    <div class="nc-ico wo">&#x1F3CB;&#xFE0F;</div>
    <div class="nc-body">
      <div class="nc-tag">ENTRENO HOY</div>
      <div class="nc-name">${esc(nm.trim())}</div>
      ${dur?`<div class="nc-meta">${esc(dur.trim())}</div>`:''}
    </div>
    <div class="nc-chk${done?' on':''}" onclick="checkWo(this)">${done?'✓':''}</div>
  </div>`;
}

function checkWo(el){
  const c=getChecks();
  c.workout=!c.workout;
  setChecks(c);
  if(c.workout)logSilent('workout',true);
  renderNextWorkout();
  refreshHomeStats();
}

function renderNextMeal(){
  const c=g$('ncm');
  if(!dietPlan){
    c.innerHTML=`<div class="nc empty" onclick="nav('dieta')"><div class="nc-ico em">+</div><div class="nc-body"><div class="nc-tag">COMIDA</div><div class="nc-name" style="color:var(--text3)">Genera tu plan de dieta</div></div></div>`;
    return;
  }
  const ORDER=['DESAYUNO','COMIDA','MERIENDA','CENA'];
  const chk=getChecks();
  let next=null,tmrw=false;
  for(const m of ORDER){if(!chk['m_'+m]){next=m;break}}
  if(!next){next='DESAYUNO';tmrw=true}

  const DAYS=['DOMINGO','LUNES','MARTES','MIÉRCOLES','JUEVES','VIERNES','SÁBADO'];
  const dow=new Date().getDay();
  const dayName=tmrw?DAYS[(dow+1)%7]:DAYS[dow];
  const mealName=getMealName(dietPlan,dayName,next)||next.charAt(0)+next.slice(1).toLowerCase();
  const timeLabel={DESAYUNO:'Mañana',COMIDA:'Mediodía',MERIENDA:'Tarde',CENA:'Noche'}[next]||next;
  const done=!tmrw&&chk['m_'+next];

  c.innerHTML=`<div class="nc${done?' done':''}">
    <div class="nc-ico ml">&#x1F374;</div>
    <div class="nc-body">
      <div class="nc-tag">${next}</div>
      <div class="nc-name">${esc(mealName)}</div>
      <div class="nc-meta${tmrw?' tmrw':''}">${tmrw?'⏰ Mañana':timeLabel}</div>
    </div>
    ${!tmrw?`<div class="nc-chk${done?' on':''}" onclick="checkMeal('${next}',this)">${done?'✓':''}</div>`:''}
  </div>`;
}

function checkMeal(meal,el){
  const c=getChecks();
  c['m_'+meal]=!c['m_'+meal];
  setChecks(c);
  renderNextMeal();
}

function getMealName(plan,day,meal){
  const lines=plan.split('\n');
  let inDay=false;
  for(const l of lines){
    const t=l.trim();
    if(/^D[ÍI]A\s+\d/i.test(t)){
      inDay=t.toUpperCase().includes(day.substring(0,3).toUpperCase());
    }
    if(inDay&&t.toUpperCase().startsWith(meal+':')){
      return t.substring(t.indexOf(':')+1).trim()||null;
    }
  }
  return null;
}

function renderWeekCal(){
  const c=g$('wcal');
  const DN=['L','M','X','J','V','S','D'];
  const now=new Date();
  const dow=now.getDay();
  const off=dow===0?-6:1-dow;
  let html='';
  for(let i=0;i<7;i++){
    const d=new Date(now);d.setDate(now.getDate()+off+i);
    const ds=d.toISOString().split('T')[0];
    const has=logs.some(l=>l.date===ds&&l.success);
    const isT=ds===todayStr();
    html+=`<div class="db${isT?' td':''}${has?' hd':''}"><span class="dn">${DN[i]}</span><span class="dd">${d.getDate()}</span><div class="dp"></div></div>`;
  }
  c.innerHTML=html;
}

function logEv(type,success){
  logSilent(type,success);
  renderWeekCal();refreshStats();refreshRing();renderHistory();refreshHomeStats();
}

function logSilent(type,success){
  const d=todayStr();
  const t=new Date().toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'});
  const idx=logs.findIndex(l=>l.date===d&&l.type===type);
  if(idx>=0)logs[idx]={date:d,type,success,time:t};
  else logs.push({date:d,type,success,time:t});
  S.set('fl_l',logs);
}

function calcStreak(){
  let s=0;const now=new Date();
  for(let i=0;i<90;i++){
    const d=new Date(now);d.setDate(now.getDate()-i);
    const ds=d.toISOString().split('T')[0];
    if(logs.some(l=>l.date===ds&&l.success))s++;else break;
  }
  return s;
}

function refreshStats(){
  const w=logs.filter(l=>l.type==='workout'&&l.success).length;
  const d2=logs.filter(l=>l.type==='diet'&&l.success).length;
  const s=calcStreak();
  g$('sw',w);g$('sd',d2);g$('ss',s);
  g$('streakbadge','🔥 '+s+' días');
  return{w,d2,s};
}

function refreshHomeStats(){
  const{w,s}=refreshStats();
  const tot=logs.length,good=logs.filter(l=>l.success).length;
  const pct=tot>0?Math.round(good/tot*100)+'%':'—';
  g$('hstreak',s);g$('hworkouts',w);g$('hcompliance',pct);
  if(profile.name){
    const h=new Date().getHours();
    const greet=h<13?'¡Buenos días, ':h<20?'¡Buenas tardes, ':'¡Buenas noches, ';
    g$('heroname',greet+profile.name.split(' ')[0]+'!');
  }
}

function refreshRing(){
  const tot=logs.length,good=logs.filter(l=>l.success).length;
  const pct=tot>0?Math.round(good/tot*100):0;
  const circ=339;
  const el=document.getElementById('rfill');
  if(el)el.style.strokeDashoffset=circ-(pct/100)*circ;
  g$('rtext',pct+'%');
}

function renderHistory(){
  const c=g$('lhist');
  if(!logs.length){c.innerHTML='<p style="font-size:13px;color:var(--text3)">Sin registros aún.</p>';return}
  const recent=[...logs].sort((a,b)=>b.date.localeCompare(a.date)||(b.time||'').localeCompare(a.time||'')).slice(0,12);
  c.innerHTML=recent.map(l=>{
    const color=l.success?'g':'r';
    const lbl=l.type==='workout'?(l.success?'✅ Entreno completado':'❌ Sin entreno'):(l.success?'🥗 Dieta seguida':'🍕 Dieta no seguida');
    return`<div class="litem"><div class="ldot ${color}"></div><div><div class="ltext">${lbl}</div><div class="ltime">${l.date}${l.time?' · '+l.time:''}</div></div></div>`;
  }).join('');
}

function loadProfile(){
  ['name','age','weight','height','goal','freq'].forEach(f=>{
    const el=document.getElementById('f-'+f);
    if(el)el.textContent=profile[f]||'—';
  });
  if(profile.name){
    g$('pname',profile.name);
    g$('psub',[profile.age&&profile.age+' años',profile.weight&&profile.weight+' kg',profile.goal].filter(Boolean).join(' · ')||'Sin datos');
  }
  if(apiKey)hideBanner();
}

function editF(f){
  const labels={name:'Nombre',age:'Edad',weight:'Peso (kg)',height:'Altura (cm)',goal:'Objetivo',freq:'Días de entreno por semana'};
  const v=prompt(labels[f]+':',profile[f]||'');
  if(v===null)return;
  profile[f]=v.trim();
  S.set('fl_p',profile);
  const el=document.getElementById('f-'+f);
  if(el)el.textContent=profile[f]||'—';
  loadProfile();
  refreshHomeStats();
}

function pCtx(){
  const e=Object.entries(profile).filter(([,v])=>v);
  return e.length?'\nPerfil del usuario: '+e.map(([k,v])=>k+': '+v).join(', '):'';
}

function clearData(){
  if(!confirm('¿Borrar todos los datos? No se puede deshacer.'))return;
  localStorage.clear();
  logs=[];profile={};apiKey='';dietPlan='';workoutPlan='';
  refreshStats();refreshRing();renderHistory();renderWeekCal();
  renderNextUp();refreshHomeStats();showBanner();loadProfile();
}

function exportData(){
  const data={profile,logs,dietPlan,workoutPlan,exportedAt:new Date().toISOString()};
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(data,null,2)],{type:'application/json'}));
  a.download='fitlife-'+todayStr()+'.json';
  a.click();
}

let chatHistory=[],chatBusy=false;
const CSYS=`Eres el asistente personal de fitness de FitLife. Responde SIEMPRE en español, de forma concisa y práctica.
Eres experto en: entrenamiento en gimnasio, nutrición, dietas (Ray Peat, bíblica, paleo, cetogénica, mediterránea, carnívora),
modificar rutinas y planes de comidas, lista de la compra con precios en Madrid (Mercadona, Lidl, Carrefour).
Cuando pidan rutina: lista ejercicios con series/reps/descanso.
Cuando pidan dieta: muestra comidas con ingredientes.
Cuando pidan modificar: confirma y muestra el resultado actualizado.`;

function openChat(){
  g$('cdrawer').classList.add('on');
  g$('coverlay').classList.add('on');
  g$('cfab').style.display='none';
  if(!chatHistory.length){
    addCMsg('ai','¡Hola! Soy tu asistente FitLife 🌿\nPuedo crear rutinas, planificar dietas, modificar ejercicios o comidas, y mucho más. ¿Por dónde empezamos?');
  }
  setTimeout(()=>g$('cin').focus(),320);
}

function closeChat(){
  g$('cdrawer').classList.remove('on');
  g$('coverlay').classList.remove('on');
  g$('cfab').style.display='flex';
}

function addCMsg(role,text){
  const c=g$('cmsgs');
  const d=document.createElement('div');
  d.className='cmsg '+role;
  d.innerHTML=`<div class="mav">${role==='ai'?'🌿':'👤'}</div><div class="mbub">${esc(text).replace(/\n/g,'<br>')}</div>`;
  c.appendChild(d);
  c.scrollTop=c.scrollHeight;
}

async function sendChat(){
  if(chatBusy)return;
  const inp=g$('cin');
  const txt=inp.value.trim();
  if(!txt)return;
  if(!apiKey){openModal();return}
  inp.value='';inp.style.height='auto';
  addCMsg('user',txt);
  chatHistory.push({role:'user',content:txt});
  chatBusy=true;
  g$('csend').disabled=true;
  g$('typbub').classList.add('on');
  g$('cmsgs').scrollTop=99999;

  let sys=CSYS+pCtx();
  if(workoutPlan)sys+='\n\nÚltima rutina:\n'+workoutPlan.substring(0,700);
  if(dietPlan)sys+='\n\nÚltimo plan de dieta:\n'+dietPlan.substring(0,1100);

  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:1200,system:sys,messages:chatHistory})
    });
    const d=await r.json();
    if(!r.ok)throw new Error(d.error?.message||'Error '+r.status);
    const reply=d.content[0].text;
    chatHistory.push({role:'assistant',content:reply});
    if(chatHistory.length>24)chatHistory=chatHistory.slice(-20);
    g$('typbub').classList.remove('on');
    addCMsg('ai',reply);
  }catch(e){
    g$('typbub').classList.remove('on');
    addCMsg('ai','Error al conectar. Comprueba tu API key en Perfil.');
  }
  chatBusy=false;
  g$('csend').disabled=false;
  g$('cmsgs').scrollTop=99999;
}

function cSug(el){g$('cin').value=el.textContent.trim();sendChat()}
function ckd(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChat()}}
function car(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,86)+'px'}

function esc(s){
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function g$(id,val){
  const el=typeof id==='string'?document.getElementById(id):id;
  if(!el)return null;
  if(val!==undefined){el.textContent=val;return el}
  return el;
}
function setLoad(id,show){const el=g$(id);if(el)el.classList.toggle('on',show)}
</script>
